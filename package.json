{
  "name": "tg-youtube-cover-bot",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/domain",
    "packages/telegram-payments",
    "packages/db",
    "packages/generation-ai",
    "packages/media-source",
    "packages/openai-image",
    "packages/storage",
    "apps/api",
    "apps/bot",
    "apps/worker",
    "apps/admin"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run build --workspaces",
    "dev:api": "npm --workspace @covers/api run dev",
    "dev:bot": "npm --workspace @covers/bot run dev",
    "dev:worker": "npm --workspace @covers/worker run dev",
    "dev:admin": "npm --workspace @covers/admin run dev",
    "test:templates": "node scripts/local-template-batch.mjs",
    "assets:bot": "node scripts/generate-bot-assets.mjs",
    "prisma:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "prisma:push": "prisma db push --skip-generate --schema packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "prisma": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
